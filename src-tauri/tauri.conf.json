{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timluli",
  "version": "1.13.0",
  "identifier": "studio.oliel.timluli",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "speech",
        "url": "speech.html",
        "title": "Timluli Engine",
        "visible": false,
        "skipTaskbar": true,
        "decorations": false,
        "resizable": false,
        "width": 240,
        "height": 240,
        "minWidth": 240,
        "minHeight": 240
      },
      {
        "label": "mic",
        "url": "mic.html",
        "title": "Timluli",
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "visible": true,
        "width": 240,
        "height": 240,
        "minWidth": 240,
        "minHeight": 240,
        "maxWidth": 240,
        "maxHeight": 240
      },
      {
        "label": "panel",
        "url": "panel.html",
        "title": "Timluli Panel",
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "visible": false,
        "width": 28,
        "height": 110
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "Timluli — הגדרות",
        "width": 820,
        "height": 640,
        "minWidth": 640,
        "minHeight": 520,
        "visible": false,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "decorations": false,
        "skipTaskbar": false
      },
      {
        "label": "onboarding",
        "url": "onboarding.html",
        "title": "Timluli — ברוך הבא",
        "dragDropEnabled": true,
        "width": 640,
        "height": 780,
        "minWidth": 640,
        "minHeight": 720,
        "resizable": false,
        "center": true,
        "visible": false,
        "skipTaskbar": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost https://www.google.com https://www.googleapis.com wss://*.google.com; media-src 'self' mediastream: blob:;"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxQTRGMzg5QUFEQTlBQzEKUldUQm10cXFpZk9rMFpyVTZ1TjNjNFJOQUE1K1E3MjM2S2x2VytGMXZXR3UwZzRFQVg1VXNDb3YK",
      "endpoints": [
        "https://github.com/ddlgap/Timluli/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "resources": {
      "resources/*": "resources/",
      "vcruntime/*.dll": "",
      "onnxruntime/*.dll": ""
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "Oliel Studio",
    "shortDescription": "תמלול קולי בעברית system-wide לווינדוס",
    "longDescription": "Timluli — כלי תמלול עברית מערכתי לווינדוס באמצעות Google Web Speech API",
    "category": "Productivity",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
